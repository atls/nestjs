{
  "name": "@atls/nestjs-oathkeeper",
  "version": "0.0.1",
  "repository": "git@github.com:atls/nestjs.git",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn library build",
    "prepack": "yarn run build",
    "postpack": "rm -rf dist"
  },
  "dependencies": {
    "@ory/oathkeeper-client-fetch": "26.2.0"
  },
  "devDependencies": {
    "@jest/globals": "29.7.0",
    "@nestjs/common": "10.4.22",
    "@nestjs/core": "10.4.22",
    "@nestjs/testing": "10.4.22",
    "@types/node": "22.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": "10",
    "@nestjs/core": "10",
    "reflect-metadata": "0.2",
    "rxjs": "7"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "dist/index.js",
    "typings": "dist/index.d.ts"
  },
  "typecheckSkipLibCheck": true
}
